# ============================================================================
# Meridian Environment Configuration
# ============================================================================

# Runtime Mode
# -----------
# "demo" - Uses pre-recorded traces and fixture data (default, no API key needed)
# "live"  - Makes live API calls to GLM-5.1 (requires ZAI_API_KEY)
# The demo mode is always used as fallback if the value is invalid or empty.
MERIDIAN_MODE=demo

# API Keys (Optional - Only Required for Live Mode)
# -----------------------------------------------
# Z.ai API key for GLM-5.1 model access
# Get your key from: https://platform.z.ai/
# Leave empty when using DEMO mode
ZAI_API_KEY=

# Service Ports (Optional)
# ---------------------
# Customize if default ports are already in use
MERIDIAN_API_PORT=8000
MERIDIAN_WEB_PORT=3000

{
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "MERIDIAN_MODE": "demo",
    "NEXT_PUBLIC_API_URL": "meridian-api.railway.app"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://meridian-api.railway.app/api/:path*"
    }
  ]
}

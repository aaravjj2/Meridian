{
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "MERIDIAN_MODE": "demo",
    "MERIDIAN_API_BASE_URL": "https://meridian-api.railway.app"
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://meridian-api.railway.app/api/v1/:path*"
    }
  ]
}

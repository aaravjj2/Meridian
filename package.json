{
  "name": "meridian",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "tsc": "tsc -p apps/web/tsconfig.json --noEmit",
    "vitest": "vitest run --config vitest.config.ts",
    "playwright": "PLAYWRIGHT=true playwright test",
    "dev": "concurrently \"uvicorn apps.api.main:app --reload --port 8000\" \"npm run -w @meridian/web dev\""
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.2",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
